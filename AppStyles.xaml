<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colors from exam style guide (Прил_3) -->
    <SolidColorBrush x:Key="AccentBrush" Color="#7FFF00"/>
    <SolidColorBrush x:Key="ButtonBrush" Color="#00FA9A"/>
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="TextBrush" Color="Black"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#00FA9A"/>
    <SolidColorBrush x:Key="FooterBrush" Color="#FFF4F4F5"/>

    <FontFamily x:Key="AppFont">Times New Roman</FontFamily>

    <!-- Default look for all windows -->
    <Style TargetType="Window">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Background" Value="{StaticResource PageBackgroundBrush}"/>
    </Style>

    <Style TargetType="Page">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Background" Value="{StaticResource PageBackgroundBrush}"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Background" Value="{StaticResource ButtonBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>

    <!-- Optional: green header bar (use later with Style="{StaticResource HeaderBorderStyle}") -->
    <Style x:Key="HeaderBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Padding" Value="15"/>
    </Style>

</ResourceDictionary>
