<Window x:Class="demo.OrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заказ" Height="320" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="12">
        <TextBlock x:Name="IdLabel" Text="ID строки" Margin="0,0,0,4"/>
        <TextBox x:Name="IdBox" IsReadOnly="True" Margin="0,0,0,8"/>
        <TextBlock Text="Артикул" Margin="0,0,0,4"/>
        <ComboBox x:Name="ArticuleCombo" Margin="0,0,0,8"/>
        <TextBlock Text="Статус" Margin="0,0,0,4"/>
        <ComboBox x:Name="StatusCombo" Margin="0,0,0,8"/>
        <TextBlock Text="Пункт выдачи" Margin="0,0,0,4"/>
        <ComboBox x:Name="AddressCombo" Margin="0,0,0,8"/>
        <TextBlock Text="Дата заказа" Margin="0,0,0,4"/>
        <DatePicker x:Name="OrderDate" Margin="0,0,0,8"/>
        <TextBlock Text="Дата выдачи" Margin="0,0,0,4"/>
        <DatePicker x:Name="DeliveryDate" Margin="0,0,0,12"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" IsDefault="True" Click="Save_Click" Margin="0,0,8,0"/>
            <Button Content="Отмена" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
